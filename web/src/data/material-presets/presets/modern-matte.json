{
  "id": "modern-matte",
  "label": "Modern Matte",
  "description": "A smoother physically based matte surface with broader highlights.",
  "material": {
    "type": "MeshStandardMaterial",
    "props": {
      "metalness": 0.1,
      "roughness": 0.6,
      "flatShading": false
    }
  },
  "overrides": {
    "polyhedron": {
      "material": {
        "type": "MeshStandardMaterial",
        "props": {
          "metalness": 0.05,
          "roughness": 0.4,
          "flatShading": false
        }
      }
    }
  },
  "lighting": [
    {
      "type": "AmbientLight",
      "props": {
        "intensity": 0.8
      }
    },
    {
      "type": "cameraDirectional",
      "props": {
        "intensity": 2.2,
        "offset": [0.3, 0.2, 0]
      }
    }
  ]
}
