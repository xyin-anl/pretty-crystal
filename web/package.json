    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gifenc": "^1.0.3",
    "lucide-react": "^0.468.0",
    "mp4-muxer": "^5.2.2",
    "pdf-lib": "^1.17.1",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
