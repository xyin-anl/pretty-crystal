  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:static": "VITE_PRETTY_CRYSTAL_STATIC_SCENE=/examples/LiFePO4.scene.json VITE_PRETTY_CRYSTAL_STATIC_SCENE_NAME='LiFePO4.cif' bun run dev",
    "build": "tsc --noEmit && vite build",
    "build:static": "VITE_PRETTY_CRYSTAL_STATIC_SCENE=/examples/LiFePO4.scene.json VITE_PRETTY_CRYSTAL_STATIC_SCENE_NAME='LiFePO4.cif' bun run build",
    "preview": "vite preview --host 127.0.0.1",
